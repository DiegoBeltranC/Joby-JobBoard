// -----------------------------------------------------------------------------
// CONFIGURACIÓN DE PRISMA
// -----------------------------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS (Catálogos fijos a nivel de base de datos)
// -----------------------------------------------------------------------------
enum EstatusEmpresa {
  SIN_ENVIAR       // Recién registrada, perfil incompleto
  PENDIENTE        // Lista para que el Admin la revise
  REQUIERE_CAMBIOS // Admin encontró errores, la empresa debe corregir
  APROBADA         // Empresa validada, puede publicar vacantes
  RECHAZADA        // Bateada en el proceso de revisión
  SUSPENDIDA       // Estaba aprobada, pero violó normas de la UTCH
}

enum TipoComunicacion {
  CORRECCION_DATOS
  RECHAZO
  AVISO_GENERAL
  SUSPENSION
}
enum EstatusAcademico {
  ACTIVO
  EGRESADO
  INACTIVO
}

// 1. Enum para la movilidad (Lo usamos en el perfil del estudiante)
enum DisponibilidadReubicacion {
  NO_DISPONIBLE
  DENTRO_DEL_ESTADO
  NACIONAL
  INTERNACIONAL
}

// 2. Enum limpio para el futuro (Lo usarán las Empresas en sus Vacantes)
enum TipoContrato {
  ESTADIA
  MEDIO_TIEMPO
  TIEMPO_COMPLETO
}

// 3. Enum para la modalidad física de la vacante (Para el futuro)
enum ModalidadTrabajo {
  PRESENCIAL
  HIBRIDO
  REMOTO
}
enum RolUsuario {
  ESTUDIANTE
  EMPRESA
  ADMIN
}

// -----------------------------------------------------------------------------
// TABLAS CATÁLOGO (Opciones dinámicas para la UI)
// -----------------------------------------------------------------------------
model Universidad {
  id           Int          @id @default(autoincrement())
  nombre       String       // Ej. "Universidad Tecnológica de Chetumal"
  siglas       String       // Ej. "UTCH"
  tipo_periodo String       // Ej. "CUATRIMESTRE" o "SEMESTRE"
  
  estudiantes  Estudiante[] 
}

model Carrera {
  id           Int          @id @default(autoincrement())
  nombre       String       // Ej. "Ingeniería de Software", "Gastronomía"
  
  estudiantes  Estudiante[]
}

// -----------------------------------------------------------------------------
// ENTIDADES PRINCIPALES
// -----------------------------------------------------------------------------
model User {
  id            Int         @id @default(autoincrement())
  correo        String      @unique
  password_hash String
  rol           RolUsuario  @default(ESTUDIANTE) 
  activo        Boolean     @default(true) // Soft delete (No borramos, desactivamos)
  
  // --- CAMPOS NUEVOS PARA VERIFICACIÓN OTP ---
  verifiedAt    DateTime?   
  otpCode       String?     
  otpExpiresAt  DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  estudiante    Estudiante? 
  empresa       Empresa?    
  admin         Admin?
}

model Estudiante {
  id                Int      @id @default(autoincrement())
  
  // Claves Foráneas
  usuarioId         Int      @unique
  universidadId     Int      
  carreraId         Int      
  
  // Datos Personales
  nombre            String
  apellidoPaterno   String
  apellidoMaterno   String?  
  matricula         String   @unique
  foto_perfil_url   String?
  estado            String?  @default("Quintana Roo")
  municipio         String?  @default("Othón P. Blanco")
  tipos_contrato TipoContrato[]
  // Logística
  reubicacion       DisponibilidadReubicacion @default(NO_DISPONIBLE)
  bio               String?  @db.Text // Su "Elevator Pitch" rápido
  
  // Estatus Académico
  estatus_academico EstatusAcademico      @default(ACTIVO)
  periodo_academico Int?                  
  
  // Perfil Profesional (El motor de búsqueda de los reclutadores)
  habilidades       String[] // ["React", "Excel", "Distintivo H"]
  idiomas           String[] // ["Inglés - B2", "Francés - A1"]
  enlaces           Json?    // { "linkedin": "...", "github": "..." }
  cv_url            String?  
  
  // Relaciones
  usuario           User           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  universidad       Universidad    @relation(fields: [universidadId], references: [id])
  carrera           Carrera        @relation(fields: [carreraId], references: [id])
  experiencias      Experiencia[]  
  proyectos         Proyecto[]     
  educacion_extra   EducacionExtra[] // Para TSU, Cursos y Certificados
  
  magicCVDraft      MagicCVDraft?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Empresa {
  id                  Int      @id @default(autoincrement())
  
  // Clave Foránea (Al igual que el estudiante, la empresa ES un usuario)
  usuarioId           Int      @unique
  
  // Datos Públicos de la Empresa (Lo que ve el alumno)
  nombre_comercial    String   // Ej: "Hotel Xcaret"
  descripcion         String?  @db.Text // A qué se dedican
  logo_url            String?
  sitio_web           String?
  enlaces             Json?    // { "linkedin": "...", "facebook": "..." }
  
  // Datos de Facturación / Verificación Legal (Lo que ve el Admin)
  razon_social        String?  // Ej: "Grupo Experiencias Xcaret S.A.P.I. de C.V."
  rfc                 String?  @unique
  estado              String?  @default("Quintana Roo")
  municipio           String?  @default("Othón P. Blanco")
  
  // Datos del Reclutador (Quién maneja la cuenta)
  nombre            String
  apellidoPaterno   String
  apellidoMaterno   String?  
  cargo_contacto      String   // Ej: "Gerente de Recursos Humanos"
  telefono_contacto   String?

  // Galería de fotos (Instalaciones de la empresa)
  fotos_empresa       String[] // URLs de fotos del local/oficinas

  // Lógica de Negocio (Verificación)
  estatus_verificacion EstatusEmpresa @default(SIN_ENVIAR)
  motivo_rechazo       String?  @db.Text // Razón de rechazo por parte del Admin
  
  // Relaciones
  usuario              User                    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vacantes             Vacante[] 
  comunicaciones       HistorialComunicacion[] // Bandeja de entrada histórica de la empresa
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Admin {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @unique
  
  // Datos Personales (Obligatorios tras el primer login)
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  telefono        String?
  
  // Jerarquía
  esSuperAdmin    Boolean  @default(false) 

  // Relaciones
  usuario         User                    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  comunicaciones  HistorialComunicacion[] // Correos que este admin ha enviado
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model Vacante {
  id                  Int      @id @default(autoincrement())
  empresaId           Int
  
  // Información de la Oferta
  titulo              String   // Ej: "Desarrollador Junior Next.js"
  descripcion         String   @db.Text
  
  // Clasificación (Usamos los Enums que ya tenías)
  tipo_contrato       TipoContrato      // ESTADIA, MEDIO_TIEMPO, etc.
  modalidad           ModalidadTrabajo  // PRESENCIAL, HIBRIDO, REMOTO
  
  // Ubicación del puesto (Puede ser distinto a la ubicación de la empresa)
  estado              String?
  municipio           String?
  // El "Match" con los alumnos
  habilidades_req     String[] // ["React", "TypeScript"] <- Esto cruzará con las habilidades del estudiante

  // Datos opcionales y control
  sueldo_min          Int?     // Para filtros de búsqueda (opcional)
  sueldo_max          Int?
  activa              Boolean  @default(true) // Si la empresa ya contrató, la pasa a false
  fecha_limite        DateTime? // Cuándo caduca la oferta
  
  // Relaciones
  empresa             Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// TABLAS DE DETALLE (Historial del Estudiante - 1 a Muchos)
// -----------------------------------------------------------------------------
model Experiencia {
  id           Int        @id @default(autoincrement())
  estudianteId Int
  puesto       String     
  empresa      String
  
  // Arreglo de viñetas (bullets) para mejor lectura de los reclutadores
  logros       String[]   // Ej: ["Mejoré el rendimiento 20%", "Lideré equipo de 3"]
  
  fechaInicio  DateTime
  fechaFin     DateTime?  // Null significa "Trabajo actual"
  
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Proyecto {
  id           Int        @id @default(autoincrement())
  estudianteId Int
  nombre       String     
  
  // Arreglo de viñetas para destacar lo importante del proyecto
  puntos_clave String[]   // Ej: ["Desarrollé app con Next.js", "Diseñé base de datos"]
  
  url_enlace   String?    // Link al repositorio o sitio en vivo
  fechaInicio  DateTime
  fechaFin     DateTime?  // Null significa "En desarrollo" o "Actual"
  
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model EducacionExtra {
  id           Int        @id @default(autoincrement())
  estudianteId Int
  titulo       String     // Ej: "TSU en Desarrollo de Software" o "Curso de Liderazgo"
  institucion  String     // Ej: "UT Chetumal" o "Platzi"
  año          Int?       // Ej: 2025
  
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model HistorialComunicacion {
  id          Int              @id @default(autoincrement())
  empresaId   Int
  adminId     Int              // Quién apretó el botón de enviar
  
  asunto      String
  mensaje     String           @db.Text
  tipo        TipoComunicacion // Categoría del mensaje
  
  // Relaciones
  empresa     Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  admin       Admin            @relation(fields: [adminId], references: [id])

  createdAt   DateTime         @default(now())
}

// -----------------------------------------------------------------------------
// BORRADOR MÁGICO DE CV (CAPA DE PRESENTACIÓN NO DESTRUCTIVA)
// -----------------------------------------------------------------------------
model MagicCVDraft {
  id           Int        @id @default(autoincrement())
  estudianteId Int        @unique
  templateId   String     @default("1")
  colorAcento  String     @default("#0F766E")
  draftState   Json       // Guarda visibilidades, texto editado y ordenamiento interactivo
  
  updatedAt    DateTime   @updatedAt
  
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}
